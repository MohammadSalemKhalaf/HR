{
  "info": {
    "_postman_id": "ems-backoffice-collection",
    "name": "EMS Backoffice",
    "description": "EMS Backoffice API workflows for job seekers, admins, companies, employees, recruitment, and leaves.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var location = (pm.execution.location || []).join(' > ');",
          "var tokenVar = '';",
          "if (location.indexOf('Platform Admin') !== -1) { tokenVar = 'admin_token'; }",
          "else if (location.indexOf('Company Management') !== -1) { tokenVar = 'company_token'; }",
          "else if (location.indexOf('Employee Self Service') !== -1) { tokenVar = 'employee_token'; }",
          "else if (location.indexOf('Job Seeker') !== -1) { tokenVar = 'seeker_token'; }",
          "if (tokenVar) {",
          "  var token = pm.environment.get(tokenVar);",
          "  if (token) { pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token }); }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Public Job Seeker Auth",
      "description": "Login and current user lookup for the seeded job seeker account.",
      "item": [
        {
          "name": "Login Job Seeker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{seeker_email}}\",\n  \"password\": \"{{seeker_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = {}; try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('Login job seeker', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
                  "if (json.data && json.data.token) { pm.environment.set('seeker_token', json.data.token); pm.environment.set('token', json.data.token); }",
                  "if (json.data && json.data.user_id) { pm.environment.set('seeker_user_id', json.data.user_id); pm.environment.set('user_id', json.data.user_id); }",
                  "if (json.data && json.data.role) { pm.environment.set('role', json.data.role); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [
            ],
            "url": {
              "raw": "{{base_url}}/api/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Current user', function () { pm.expect(pm.response.code).to.be.within(200, 299); });"
                ]
              }
            }
          ]
        }
      ]
    },
