                  "pm.test('Get all vacancies', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
                  "if (Array.isArray(json.data) && json.data.length > 0) { pm.environment.set('vacancy_id', json.data[0].id); if (json.data[0].company && json.data[0].company.id) { pm.environment.set('company_id', json.data[0].company.id); } else if (json.data[0].companyId) { pm.environment.set('company_id', json.data[0].companyId); } }"
