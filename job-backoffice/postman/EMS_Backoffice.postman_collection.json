        {
          "name": "Apply To Vacancy",
          "description": "Apply to a job vacancy. Supply EITHER resume_id (for existing resume) OR cv_file (to upload new resume). Do not supply both.",
          "request": {
            "method": "POST",
            "header": [
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "user_id",
                  "value": "{{seeker_user_id}}",
                  "type": "text"
                },
                {
                  "key": "job_vacancy_id",
                  "value": "{{vacancy_id}}",
                  "type": "text"
                },
                {
                  "key": "resume_id",
                  "value": "{{resume_id}}",
                  "type": "text",
                  "disabled": false
                },
                {
                  "key": "cv_file",
                  "type": "file",
                  "disabled": true,
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/applications",
              "host": [
                "{{base_url}}"
              ],
