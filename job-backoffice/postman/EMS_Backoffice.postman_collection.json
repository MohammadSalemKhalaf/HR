    {
      "name": "Public Job Seeker Auth",
      "description": "Public registration is only for job seekers.",
      "item": [
        {
          "name": "Register Job Seeker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_api_url}}/auth/register"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Job Seeker\",\n  \"email\": \"seeker{{$timestamp}}@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"job_seeker\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = {}; try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('Register job seeker', function () { pm.expect(pm.response.code).to.be.within(200, 299); });",
                  "if (json.data && json.data.token) { pm.environment.set('seeker_token', json.data.token); pm.environment.set('token', json.data.token); }",
                  "if (json.data && json.data.user_id) { pm.environment.set('seeker_user_id', json.data.user_id); pm.environment.set('user_id', json.data.user_id); }",
                  "if (json.data && json.data.role) { pm.environment.set('role', json.data.role); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Job Seeker",
